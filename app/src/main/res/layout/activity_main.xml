<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0a1628">

    <!-- Live WebView -->
    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ── Offline screen ──────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/offlineView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/splash_background"
        android:paddingLeft="48dp"
        android:paddingRight="48dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_no_connection"
            android:layout_marginBottom="28dp"
            android:contentDescription="No connection" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No connection"
            android:textColor="#f1f5f9"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Check your internet and try again"
            android:textColor="#475569"
            android:textSize="15sp"
            android:gravity="center"
            android:layout_marginBottom="40dp" />

        <Button
            android:id="@+id/retryButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Try Again"
            android:textColor="#0f172a"
            android:textStyle="bold"
            android:textSize="14sp"
            android:background="@drawable/button_retry"
            android:paddingLeft="36dp"
            android:paddingRight="36dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:stateListAnimator="@null" />
    </LinearLayout>

    <!-- ── Splash screen ──────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/splashView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/splash_background">

        <!-- Icon card -->
        <FrameLayout
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:background="@drawable/splash_icon_bg"
            android:layout_marginBottom="28dp">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_launcher_foreground"
                android:contentDescription="SkyBook" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SkyBook"
            android:textColor="#f1f5f9"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your booking workspace"
            android:textColor="#334155"
            android:textSize="15sp"
            android:layout_marginBottom="60dp" />

        <ProgressBar
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:indeterminate="true"
            android:indeterminateTint="#d4a843" />

    </LinearLayout>

</FrameLayout>
